{
  "name": "@pleasync/schema",
  "version": "0.1.0-beta.3",
  "description": "Schema DSL parser, AST, and validator for pleasync",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "license": "MIT",
  "keywords": ["pleasanter", "schema", "yaml", "dsl", "validator"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sasakiyusuke2017015/pleasync.git",
    "directory": "packages/schema"
  },
  "homepage": "https://github.com/sasakiyusuke2017015/pleasync/tree/main/packages/schema#readme",
  "bugs": {
    "url": "https://github.com/sasakiyusuke2017015/pleasync/issues"
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "tsc -p .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
